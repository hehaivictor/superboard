{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "persona_id",
    "name",
    "committee",
    "ontology_level",
    "source_quality",
    "version",
    "concepts",
    "decision_rules",
    "failure_modes",
    "confidence_boundary",
    "source_map",
    "case_map",
    "not_for",
    "calibration_notes",
    "display_name",
    "english_name",
    "activation",
    "representative_viewpoints",
    "evidence_thresholds",
    "counter_tests",
    "misuse_guardrails"
  ],
  "properties": {
    "persona_id": {
      "type": "string"
    },
    "ontology_level": {
      "enum": [
        "core",
        "triggered_specialist",
        "distilled_archive"
      ]
    },
    "decision_rules": {
      "type": "array"
    },
    "display_name": {
      "type": "string"
    },
    "english_name": {
      "type": "string"
    },
    "activation": {
      "type": "object"
    },
    "representative_viewpoints": {
      "type": "array"
    },
    "evidence_thresholds": {
      "type": "array"
    },
    "counter_tests": {
      "type": "array"
    },
    "misuse_guardrails": {
      "type": "array"
    }
  }
}
