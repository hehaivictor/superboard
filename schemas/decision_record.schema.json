{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Super Board Decision Record",
  "type": "object",
  "required": [
    "decision_id",
    "created_at",
    "input_type",
    "mode_id",
    "title",
    "decision",
    "ontology_trace",
    "ontology_rule_hits",
    "committee_rule_matrix",
    "triggered_specialists",
    "assumptions",
    "evidence_packets",
    "follow_up_checkpoints",
    "selected_seats",
    "seat_viewpoints",
    "seat_selection_trace",
    "persona_graph_refs",
    "model_comparisons",
    "action_audit",
    "governance_checks",
    "ontology_update_candidates"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "input_type": {
      "type": "string",
      "enum": [
        "product_requirement",
        "project_plan",
        "business_plan",
        "unknown"
      ]
    },
    "mode_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "Go",
        "Pivot",
        "No-Go",
        "Pending"
      ]
    },
    "ontology_trace": {
      "type": "array",
      "items": {
        "$ref": "../ontology/schemas/ontology_trace.schema.json"
      }
    },
    "ontology_rule_hits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "persona_id",
          "committee",
          "rule_id",
          "triggered_by",
          "missing_evidence",
          "counter_test"
        ],
        "properties": {
          "persona_id": {
            "type": "string"
          },
          "persona_name": {
            "type": "string"
          },
          "committee": {
            "type": "string"
          },
          "rule_id": {
            "type": "string"
          },
          "triggered_by": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missing_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "counter_test": {
            "type": "string"
          },
          "confidence_boundary": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "claim_id": {
            "type": "string"
          },
          "model_id": {
            "type": "string"
          },
          "source_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "boundary_id": {
            "type": "string"
          },
          "counter_test_id": {
            "type": "string"
          },
          "relation_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "governance_checks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "committee_rule_matrix": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "triggered_specialists": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "evidence_packets": {
      "type": "array",
      "items": {
        "$ref": "evidence_packet.schema.json"
      }
    },
    "follow_up_checkpoints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "selected_seats": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "seat_viewpoints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "seat_selection_trace": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "persona_graph_refs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "model_comparisons": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "action_audit": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "governance_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ontology_update_candidates": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
