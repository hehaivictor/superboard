{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Super Board Material Pack",
  "type": "object",
  "required": ["pack_id", "title", "files", "source_blocks", "warnings"],
  "properties": {
    "pack_id": { "type": "string" },
    "title": { "type": "string" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file_id", "name", "size", "type", "status"],
        "properties": {
          "file_id": { "type": "string" },
          "name": { "type": "string" },
          "size": { "type": "number" },
          "type": { "type": "string" },
          "status": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "source_blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["block_id", "file_id", "source_file", "text"],
        "properties": {
          "block_id": { "type": "string" },
          "file_id": { "type": "string" },
          "source_file": { "type": "string" },
          "text": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
