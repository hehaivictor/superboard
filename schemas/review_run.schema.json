{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Super Board Review Run",
  "type": "object",
  "required": ["run_id", "mode_id", "stages"],
  "properties": {
    "run_id": { "type": "string" },
    "mode_id": { "type": "string" },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage_id", "name", "status"],
        "properties": {
          "stage_id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "summary": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
